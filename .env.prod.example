# ── Domain ────────────────────────────────────────────────────────────────────
# Your VPS domain (must have DNS A records pointing to this server)
# dashboard → https://DOMAIN
# ingestion  → https://ingest.DOMAIN
DOMAIN=observabox.yourdomain.com

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_DB=observabox
CLICKHOUSE_USER=observabox
CLICKHOUSE_PASSWORD=change_this_strong_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_hex_string

# ── Ingestion API ─────────────────────────────────────────────────────────────
# SDK clients must send this key in the x-api-key header
INGESTION_API_KEY=replace_with_a_strong_api_key

# ── AI (optional) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
