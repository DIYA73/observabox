{
  "name": "observabox/laravel-sdk",
  "description": "ObservaBox SDK for Laravel — logs, metrics, and traces",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "ObservaBox\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": ["ObservaBox\\ObservaBoxServiceProvider"],
      "aliases": {
        "ObservaBox": "ObservaBox\\Facades\\ObservaBox"
      }
    }
  },
  "minimum-stability": "stable"
}
